    <!-- Consent -->
    <string name="consent_title">सूचित सहमति</string>
    <string name="consent_body">\'मैं सहमत हूँ\' पर क्लिक करके, आप प्रतिमर्ष नस्य क्लिनिकल ट्रायल में भाग लेने के लिए अपनी सहमति देते हैं। आप दिन में दो बार अपनी खुराक लॉग करने और इस एप्लिकेशन का उपयोग करके किसी भी प्रतिकूल घटना की तुरंत रिपोर्ट करने के लिए सहमत हैं। आपका डेटा ट्रायल निगरानी उद्देश्यों के लिए सुरक्षित रूप से संग्रहीत किया जाएगा।</string>
