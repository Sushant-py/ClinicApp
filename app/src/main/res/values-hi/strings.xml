    <!-- Onboarding / Tutorial Steps -->
    <string name="onboarding_welcome">ट्रायल में आपका स्वागत है</string>
    <string name="step_1_title">चरण 1: उपयोग</string>
    <string name="step_1_desc">हर सुबह (8 AM) और शाम (8 PM) प्रत्येक नथुने में नस्य तेल की बिल्कुल 2 बूंदें डालें।</string>
    <string name="step_2_title">चरण 2: पुष्टि</string>
    <string name="step_2_desc">खुराक डालने के बाद, इस ऐप को खोलें और अपनी खुराक की पुष्टि करने के लिए \'सुबह\' या \'शाम\' बटन दबाएं।</string>
    <string name="step_3_title">चरण 3: सुरक्षा और रिपोर्टिंग</string>
    <string name="step_3_desc">यदि आप रक्तस्राव, गंभीर दर्द या सांस लेने में कठिनाई का अनुभव करते हैं, तो तुरंत \'समस्या की रिपोर्ट करें\' बटन का उपयोग करें।</string>
