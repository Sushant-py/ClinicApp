    <!-- Consent -->
    <string name="consent_title">ತಿಳುವಳಿಕೆಯುಳ್ಳ ಒಪ್ಪಿಗೆ</string>
    <string name="consent_body">\'ನಾನು ಒಪ್ಪುತ್ತೇನೆ\' ಕ್ಲಿಕ್ ಮಾಡುವ ಮೂಲಕ, ನೀವು ಪ್ರತಿಮಾರ್ಷ ನಸ್ಯ ಕ್ಲಿನಿಕಲ್ ಟ್ರಯಲ್‌ನಲ್ಲಿ ಭಾಗವಹಿಸಲು ಒಪ್ಪುತ್ತೀರಿ. ನೀವು ದಿನಕ್ಕೆ ಎರಡು ಬಾರಿ ನಿಮ್ಮ ಡೋಸ್‌ಗಳನ್ನು ಲಾಗ್ ಮಾಡಲು ಮತ್ತು ಈ ಅಪ್ಲಿಕೇಶನ್ ಬಳಸಿ ಯಾವುದೇ ಅಡ್ಡ ಪರಿಣಾಮಗಳನ್ನು ತಕ್ಷಣವೇ ವರದಿ ಮಾಡಲು ಒಪ್ಪುತ್ತೀರಿ. ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಟ್ರಯಲ್ ಮೇಲ್ವಿಚಾರಣೆಯ ಉದ್ದೇಶಗಳಿಗಾಗಿ ಸುರಕ್ಷಿತವಾಗಿ ಸಂಗ್ರಹಿಸಲಾಗುತ್ತದೆ.</string>
    <string name="oil_accountability">ನಸ್ಯ ಎಣ್ಣೆಯ ಹೊಣೆಗಾರಿಕೆ</string>
    <string name="batch_hint">ಎಣ್ಣೆಯ ಬ್ಯಾಚ್/ಲಾಟ್ ಸಂಖ್ಯೆಯನ್ನು ನಮೂದಿಸಿ</string>
    <string name="expiry_hint">ಮುಕ್ತಾಯ ದಿನಾಂಕವನ್ನು ನಮೂದಿಸಿ (MM/YYYY)</string>
    <string name="agree_submit">ನಾನು ಒಪ್ಪುತ್ತೇನೆ ಮತ್ತು ಸಲ್ಲಿಸುತ್ತೇನೆ</string>

    <!-- Onboarding / Tutorial Steps -->
    <string name="onboarding_welcome">ಟ್ರಯಲ್‌ಗೆ ಸುಸ್ವಾಗತ</string>
    <string name="step_1_title">ಹಂತ 1: ಅನ್ವಯಿಸುವುದು</string>
    <string name="step_1_desc">ಪ್ರತಿದಿನ ಬೆಳಿಗ್ಗೆ (8 AM) and ಸಂಜೆ (8 PM) ಪ್ರತಿ ಮೂಗಿನ ಹೊಳ್ಳೆಗೆ ಸರಿಯಾಗಿ 2 ಹನಿ ನಸ್ಯ ಎಣ್ಣೆಯನ್ನು ಅನ್ವಯಿಸಿ.</string>
    <string name="step_2_title">ಹಂತ 2: ದೃಢೀಕರಣ</string>
    <string name="step_2_desc">ಅನ್ವಯಿಸಿದ ನಂತರ, ಈ ಅಪ್ಲಿಕೇಶನ್ ತೆರೆಯಿರಿ ಮತ್ತು ನಿಮ್ಮ ಡೋಸ್ ಅನ್ನು ದೃಢೀಕರಿಸಲು \'ಬೆಳಿಗ್ಗೆ\' ಅಥವಾ \'ಸಂಜೆ\' ಬಟನ್ ಒತ್ತಿರಿ.</string>
    <string name="step_3_title">ಹಂತ 3: ಸುರಕ್ಷತೆ ಮತ್ತು ವರದಿ</string>
    <string name="step_3_desc">ನೀವು ರಕ್ತಸ್ರಾವ, ತೀವ್ರ ನೋವು ಅಥವಾ ಉಸಿರಾಟದ ತೊಂದರೆಯನ್ನು ಅನುಭವಿಸಿದರೆ, ತಕ್ಷಣವೇ \'ಅಡ್ಡ ಪರಿಣಾಮ ವರದಿ ಮಾಡಿ\' ಬಟನ್ ಬಳಸಿ.</string>
